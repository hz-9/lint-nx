{
  "name": "lint-nx",
  "private": true,
  "description": "A collection of JavaScript/TypeScript lint configurations (ESLint + Prettier) — Nx workspace",
  "scripts": {
    "nx": "nx",
    "build": "nx run-many --target=build --all",
    "lint": "eslint --fix packages/",
    "test": "nx run-many --target=test --all",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,ts,json,css,md}\"",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "publish": "bash ./scripts/release.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@commitlint/cli": "^19.2.2",
    "@commitlint/config-conventional": "^19.2.2",
    "@hz-9/eslint-config-airbnb": "workspace:*",
    "@hz-9/prettier-config": "workspace:*",
    "@nx/vite": "19.0.0",
    "@trivago/prettier-plugin-sort-imports": "^4.3.0",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "nx": "19.0.0",
    "prettier": "^3.2.5",
    "typescript": ">=5.0.0 <5.4.0",
    "vitest": "^1.3.1"
  },
  "engines": {
    "node": ">=18.18.0 <19.0.0 || >=20.9.0 <21.0.0"
  },
  "packageManager": "pnpm@8.15.9"
}
