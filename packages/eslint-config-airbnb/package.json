{
  "name": "@hz-9/eslint-config-airbnb",
  "version": "0.7.1",
  "description": "A eslint config for 'hz-9' (JavaScript)",
  "keywords": [
    "eslint",
    "airbnb"
  ],
  "homepage": "https://hz-9.github.io/lint-nx/guide/eslint-config-airbnb",
  "bugs": {
    "url": "https://github.com/hz-9/lint-nx/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hz-9/lint-nx.git",
    "directory": "packages/eslint-config-airbnb"
  },
  "license": "MIT",
  "author": "Chen Zhen <heavenzhen999@163.com>",
  "exports": {
    ".": {
      "import": "./lib/profile/index.mjs",
      "require": "./lib/profile/index.js"
    },
    "./airbnb-base": {
      "import": "./lib/profile/airbnb-base.mjs",
      "require": "./lib/profile/airbnb-base.js"
    },
    "./airbnb-prettier": {
      "import": "./lib/profile/airbnb-prettier.mjs",
      "require": "./lib/profile/airbnb-prettier.js"
    },
    "./index": {
      "import": "./lib/profile/index.mjs",
      "require": "./lib/profile/index.js"
    },
    "./package.json": "./package.json",
    "./flat": {
      "import": "./lib/profile/flat.mjs",
      "require": "./lib/profile/flat.js"
    },
    "./flat/airbnb-base": {
      "import": "./lib/profile/flat-airbnb-base.mjs",
      "require": "./lib/profile/flat-airbnb-base.js"
    },
    "./flat/airbnb-prettier": {
      "import": "./lib/profile/flat-airbnb-prettier.mjs",
      "require": "./lib/profile/flat-airbnb-prettier.js"
    },
    "./*": {
      "import": "./lib/*.mjs",
      "require": "./lib/*.js"
    }
  },
  "main": "./lib/profile/index.js",
  "files": [
    "lib",
    "LICENSE",
    "CHANGELOG.md",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs"
  },
  "dependencies": {
    "confusing-browser-globals": "^1.0.10",
    "eslint-plugin-import": "^2.32.0",
    "semver": "^6.3.0"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0"
  },
  "peerDependencies": {
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.18.0 <19.0.0 || >=20.9.0 <21.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
